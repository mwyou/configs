# 自定义节点
proxies:
  - {name: 🏠 Direct, type: direct}

# 订阅节点
proxy-providers:
  Airport1:
    url: "https://example.com/sub/xxxx"
    type: http
    interval: 3600
    health-check:
      enable: true
      url: https://cp.cloudflare.com/generate_204
      interval: 300

# 全局配置
mode: rule
mixed-port: 7890
allow-lan: false
ipv6: false
unified-delay: true
tcp-concurrent: true
log-level: warning
global-client-fingerprint: chrome

profile:
  store-selected: true
  store-fake-ip: true

# 嗅探
sniffer:
  enable: true
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]
  force-domain:
    - "+.v2ex.com"
  skip-domain:
    - "+.baidu.com"
    - "+.qq.com"
    - "+.taobao.com"
    - "+.jd.com"
    - "+.alicdn.com"
    - "+.mi.com"
    - "+.xiaomi.com"

# DNS
dns:
  enable: true
  listen: 127.0.0.1:1053
  ipv6: false
  respect-rules: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - "rule-set:private,cn"
    - "+.lan"
    - "+.local"
    - "+.localdomain"
    - "+.home.arpa"
    - "+.msftconnecttest.com"
    - "+.msftncsi.com"
    - "time.*.com"
    - "time.*.gov"
    - "time.*.edu.cn"
    - "+.ntp.org.cn"
    - "+.pool.ntp.org"
    - "+.market.xiaomi.com"
    - "+.tailscale.com"
    - "+.tailscale.io"
    - "+.ts.net"
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  proxy-server-nameserver:
    - https://223.5.5.5/dns-query
    - https://1.12.12.12/dns-query
  nameserver:
    - 223.5.5.5
    - 119.29.29.29

pr: &pr {type: select, proxies: [🏠 Direct, 🧭 Proxy Select]}

proxy-groups:
  - {name: 🧭 Proxy Select, type: select, proxies: [🏠 Direct], include-all: true, filter: "(?i)新加坡|日本|台湾|美国|racknerd|cotelforce|mwyou168|C202604211042848"}
  - {name: 📹 YouTube,      <<: *pr, include-all: true}
  - {name: 🅖 Google,       <<: *pr, include-all: true}
  - {name: 💻 GitHub,       <<: *pr, include-all: true}
  - {name: 🤖 AI,           <<: *pr, include-all: true}
  - {name: 🎬 Netflix,      <<: *pr, include-all: true}
  - {name: ✈️ Telegram,     <<: *pr, include-all: true}
  - {name: 🎵 TikTok,       <<: *pr, include-all: true}
  - {name: 🐳 Docker,       <<: *pr, include-all: true}
  - {name: 𝕏 Twitter,      <<: *pr, include-all: true}
  - {name: ☁️ OneDrive,     <<: *pr, include-all: true}
  - {name: 🪟 Microsoft,    <<: *pr, include-all: true}
  - {name: 💳 PayPal,       <<: *pr, include-all: true}
  - {name: 🍎 Apple,        <<: *pr, include-all: true}
  - {name: 🐟 Others,       <<: *pr}

rules:
  - RULE-SET,private,🏠 Direct
  - RULE-SET,private_ip,🏠 Direct,no-resolve
  - RULE-SET,cn,🏠 Direct
  - RULE-SET,cn_ip,🏠 Direct,no-resolve

  # Tailscale 直连
  - DOMAIN-SUFFIX,tailscale.com,🏠 Direct
  - DOMAIN-SUFFIX,tailscale.io,🏠 Direct
  - DOMAIN-SUFFIX,ts.net,🏠 Direct

  # Google Scholar 走代理，其余学术站点直连
  - DOMAIN-SUFFIX,scholar.google.com,🅖 Google
  - DOMAIN-SUFFIX,scholar.googleusercontent.com,🅖 Google
  - RULE-SET,scholar_cn,🏠 Direct
  - RULE-SET,scholar,🏠 Direct

  - RULE-SET,youtube,📹 YouTube
  - RULE-SET,google,🅖 Google
  - RULE-SET,google_ip,🅖 Google,no-resolve
  - RULE-SET,github,💻 GitHub
  - RULE-SET,ai,🤖 AI
  - RULE-SET,netflix,🎬 Netflix
  - RULE-SET,netflix_ip,🎬 Netflix,no-resolve
  - RULE-SET,telegram,✈️ Telegram
  - RULE-SET,telegram_ip,✈️ Telegram,no-resolve
  - RULE-SET,tiktok,🎵 TikTok
  - RULE-SET,docker,🐳 Docker
  - RULE-SET,twitter,𝕏 Twitter
  - RULE-SET,twitter_ip,𝕏 Twitter,no-resolve
  - RULE-SET,onedrive,☁️ OneDrive
  - RULE-SET,microsoft,🪟 Microsoft
  - RULE-SET,apple,🍎 Apple
  - RULE-SET,paypal,💳 PayPal
  - RULE-SET,geolocation-!cn,🧭 Proxy Select
  - MATCH,🐟 Others

rule-anchor:
  ip: &ip {type: http, interval: 86400, behavior: ipcidr, format: mrs}
  domain: &domain {type: http, interval: 86400, behavior: domain, format: mrs}

